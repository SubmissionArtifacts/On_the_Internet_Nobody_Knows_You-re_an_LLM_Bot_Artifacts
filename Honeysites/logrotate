/var/log/nginx/access.log {
    daily
    missingok
    rotate 99999
    compress
    notifempty
    dateext
    copytruncate
    olddir /var/log/nginx/old_logs
    dateformat -%Y-%m-%d
    create 644 root root
    sharedscripts
    postrotate
        [ ! -f /var/run/nginx.pid ] || kill -USR1 `cat /var/run/nginx.pid`
    endscript
}
